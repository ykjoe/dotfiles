# WSL2 Proxy Configuration
# export WSL_HOST_IP=$(powershell.exe -Command "(Get-NetIPAddress -AddressFamily IPv4 | Where-Object { \$_.InterfaceAlias -notlike '*Loopback*' -and \$_.IPAddress -notlike '169.*' -and \$_.IPAddress -notlike '10.255.*' } | Select-Object -First 1).IPAddress" | tr -d '\r')
export WSL_HOST_IP="127.0.0.1"
export http_proxy="http://${WSL_HOST_IP}:30808"
export https_proxy="http://${WSL_HOST_IP}:30808"
export HTTP_PROXY="http://${WSL_HOST_IP}:30808"
export HTTPS_PROXY="http://${WSL_HOST_IP}:30808"
export no_proxy="127.0.0.1,localhost,192.168.*,172.*,10.*"
export NO_PROXY="127.0.0.1,localhost,192.168.*,172.*,10.*"
